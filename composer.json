{
    "name": "utopia-php/servers",
    "description": "A base library for building Utopia style servers.",
    "type": "library",
    "keywords": [
        "php",
        "framework",
        "upf",
        "utopia",
        "servers"
    ],
    "license": "MIT",
    "minimum-stability": "stable",
    "authors": [
        {
            "name": "Team Appwrite",
            "email": "team@appwrite.io"
        }
    ],
    "autoload": {
        "psr-4": {
            "Utopia\\Servers\\": "src/Servers"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\Servers\\Unit\\": "tests/Servers/Unit"
        }
    },
    "scripts": {
        "test": "phpunit"
    },
    "require": {
        "php": ">=8.2",
        "utopia-php/di": "^0.3",
        "utopia-php/validators": "^0.2"
    }
}
